{
  "name": "gatsby-source-pg",
  "version": "1.0.0-rc.0",
  "description": "PostgreSQL source for Gatsby, powered by PostGraphile",
  "main": "index.js",
  "scripts": {
    "lint:fix": "yarn prettier --write && yarn eslint --fix",
    "prettier": "prettier --ignore-path .prettierignore '**/*.{js,jsx,ts,tsx,graphql,md,yaml,yml}'",
    "eslint": "eslint --ext js,jsx,ts,tsx .",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphile/gatsby-source-pg.git"
  },
  "keywords": [
    "gatsby",
    "gatsby-plugin",
    "gatsby-source-plugin",
    "source",
    "plugin",
    "pg",
    "postgres",
    "postgresql",
    "sql",
    "psql",
    "pgsql",
    "postgraphile",
    "graphile",
    "postgraphql"
  ],
  "author": "Benjie Gillam <code@benjiegillam.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/graphile/gatsby-source-pg/issues"
  },
  "homepage": "https://github.com/graphile/gatsby-source-pg#readme",
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "gatsby-source-graphql": "^5.16.0",
    "pg": "^8.20.0",
    "postgraphile": "^5.0.0"
  },
  "peerDependencies": {
    "gatsby": "^5.0.0",
    "graphql": "^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint_d": "^15.0.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1"
  },
  "files": [
    "/lib",
    "/index.js",
    "/gatsby-node.js"
  ]
}
