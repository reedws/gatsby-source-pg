{
  "name": "gatsby-source-pg",
  "version": "1.0.0-rc.0",
  "description": "PostgreSQL source for Gatsby, powered by PostGraphile",
  "main": "index.js",
  "scripts": {
    "lint:fix": "yarn prettier --write && yarn eslint --fix",
    "prettier": "prettier --ignore-path .eslintignore '**/*.{js,jsx,ts,tsx,graphql,md,yaml,yml}'",
    "eslint": "eslint --ext js,jsx,ts,tsx .",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphile/gatsby-source-pg.git"
  },
  "keywords": [
    "gatsby",
    "gatsby-plugin",
    "gatsby-source-plugin",
    "source",
    "plugin",
    "pg",
    "postgres",
    "postgresql",
    "sql",
    "psql",
    "pgsql",
    "postgraphile",
    "graphile",
    "postgraphql"
  ],
  "author": "Benjie Gillam <code@benjiegillam.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/graphile/gatsby-source-pg/issues"
  },
  "homepage": "https://github.com/graphile/gatsby-source-pg#readme",
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "gatsby-source-graphql": "^5.16.0",
    "pg": "^8.20.0",
    "postgraphile": "^5.0.0"
  },
  "peerDependencies": {
    "graphql": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "gatsby": "^5.0.0"
  },
  "devDependencies": {
    "@graphql-eslint/eslint-plugin": "^3.20.1",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint_d": "^9.1.2",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^23.20.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^2.8.8"
  },
  "files": [
    "/lib",
    "/index.js",
    "/gatsby-node.js"
  ]
